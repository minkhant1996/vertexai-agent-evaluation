# ===========================================
# Founder Validation Agent - Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# Gemini API Key (REQUIRED)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Project (for deployment and Vertex AI evaluation)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# PostgreSQL Database (OPTIONAL)
# Uncomment to enable database persistence
# DATABASE_URL=postgresql://user:password@localhost:5432/founder_validate

# Environment
NODE_ENV=development

# Agent URL (for evaluation scripts)
AGENT_URL=http://localhost:8101

# ===========================================
# Optional: Security Settings (Production)
# ===========================================

# API Key for authenticating requests (optional)
# API_KEY=your_api_key_here

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:8100,https://yourdomain.com

# Rate limiting (requests per minute)
# RATE_LIMIT=100
