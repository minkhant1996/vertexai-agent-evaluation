{
  "name": "founder-validate-agent",
  "version": "1.0.0",
  "description": "SoeMind Foundry Idea Validation Agent - helps founders turn raw ideas into validation plans",
  "main": "src/agent.ts",
  "scripts": {
    "dev": "concurrently --names API,WEB --prefix-colors yellow,green \"npm run api\" \"cd frontend && npm run dev\"",
    "dev:adk": "npx adk web",
    "dev:auth": "tsx src/auth-proxy.ts",
    "dev:all": "concurrently --names API,WEB --prefix-colors yellow,green \"npm run api\" \"cd frontend && npm run dev\"",
    "start": "npx adk run src/agent.ts",
    "api": "npx tsx --env-file=.env src/api/server.ts",
    "build": "tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "echo \"Error: no test specified\" && exit 1",
    "simulate": "tsx src/scripts/run-simulation.ts",
    "eval": "AGENT_ENDPOINT=http://localhost:8000 tsx src/scripts/run-simulation.ts",
    "eval:verbose": "AGENT_ENDPOINT=http://localhost:8000 tsx src/scripts/run-simulation.ts --verbose",
    "eval:deployed": "./scripts/run-eval.sh --deployed",
    "eval:deployed:verbose": "./scripts/run-eval.sh --deployed --verbose",
    "track2:migrate": "prisma migrate dev --name add_track2_models"
  },
  "keywords": [
    "adk",
    "gemini",
    "agent",
    "startup",
    "validation",
    "founder",
    "a2a",
    "multi-agent"
  ],
  "author": "SoeMind Foundry",
  "license": "Apache-2.0",
  "type": "module",
  "dependencies": {
    "@google-cloud/aiplatform": "^6.8.1",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/trace-agent": "^8.0.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/adk": "^1.1.0",
    "@google/genai": "^2.8.0",
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "http-proxy-middleware": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@google/adk-devtools": "^1.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^8.2.2",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
